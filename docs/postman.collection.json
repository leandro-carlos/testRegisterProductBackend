          "mode": "raw",
          "raw": "{\n  \"email\": \"leandro@example.com\",\n  \"password\": \"StrongPassword123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": ["{{baseUrl}}"],
