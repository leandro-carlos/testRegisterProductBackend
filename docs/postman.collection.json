{
  "info": {
    "name": "Product Management API",
    "_postman_id": "f1ea8a1b-97d8-48bb-a6e3-857b56972341",
    "description": "Colecao Postman para a API NestJS de gerenciamento de produtos.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"leandro\",\n  \"email\": \"leandro@example.com\",\n  \"password\": \"StrongPassword123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "register"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const response = pm.response.json();",
              "pm.environment.set('accessToken', response.tokens.accessToken);",
              "pm.environment.set('refreshToken', response.tokens.refreshToken);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Auth - Login",
